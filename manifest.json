{
  "manifest_version": 2,
  "name": "YouTube Arrow Fix",
  "version": "1.2",
  "description": "Фикс поведения строк {верх: пеовышение громкости на 10%, низ: понижение громкости на 10%, право: +5 сек., лево: -5 сек.}",
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-arrow-fix@localhost",
      "data_collection_permissions": {
        "required": [
            "none"
        ],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["main.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  }
}